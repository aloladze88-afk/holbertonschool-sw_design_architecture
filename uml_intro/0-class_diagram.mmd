classDiagram

class Library {
    +add_book()
    +register_user()
    +create_loan()
}

class Book {
    +str title
    +str author
    +bool state
    +mark_as_unavailable()
    +mark_as_available()
}

class User {
    +str name
    +str email
}

class Loan {
    +str start_date
    +str end_date
    +close_loan()
}

Library "1" o-- "0..*" Book : manages
Library "1" o-- "0..*" User : manages
Library "1" o-- "0..*" Loan : creates
Loan "0..*" --> "1" Book : references
Loan "0..*" --> "1" User : references
